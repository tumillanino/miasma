#!/usr/bin/env bash

set -xeuo pipefail

mkdir -p "${SRCDIR}/cache"

if [ ! -e "${SRCDIR}/cache/crane" ]; then
  CRANE_URL=$(curl -fsSL https://api.github.com/repos/google/go-containerregistry/releases/latest |
    jq -rc --arg arch $(arch | sed s/aarch/arm/) \
      '.assets[] | select(.name == "go-containerregistry_Linux_" + $arch + ".tar.gz") | .browser_download_url')
  curl -fsSLo /dev/stdout "${CRANE_URL}" | tar -xvzf - -C "${SRCDIR}/cache" --owner=0 --group=0 --no-same-owner --no-same-permissions crane
fi

if [ ! -e "${SRCDIR}/cache/homebrew.tar.zst" ]; then
  "${SRCDIR}/cache/crane" export ghcr.io/ublue-os/brew:latest | tar -xvf - -C "${SRCDIR}/cache" system_files/usr/share/homebrew.tar.zst
  mv "${SRCDIR}/cache/system_files/usr/share/homebrew.tar.zst" "${SRCDIR}/cache/homebrew.tar.zst"
  rm -r "${SRCDIR}/cache/system_files"
fi

if [ ! -e "${SRCDIR}/cache/flathub.flatpakrepo" ]; then
  curl --retry 3 -Lo "${SRCDIR}/cache/flathub.flatpakrepo" "https://dl.flathub.org/repo/flathub.flatpakrepo"
fi

if [ ! -e "${SRCDIR}/cache/Gruvbox-Plus-Dark" ]; then
  GRUVBOX_URL=$(curl -fsSL https://api.github.com/repos/SylEleuth/gruvbox-plus-icon-pack/releases/latest | \
    jq -rc '.assets[] | select(.name | endswith(".zip")) | .browser_download_url')
  GRUVBOX_ZIP="$(basename "${GRUVBOX_URL}")"
  curl -fsSLo "${SRCDIR}/cache/${GRUVBOX_ZIP}" "${GRUVBOX_URL}"
  unzip -q "${SRCDIR}/cache/${GRUVBOX_ZIP}" -d "${SRCDIR}/cache/gruvbox-extract/"
  find "${SRCDIR}/cache/gruvbox-extract/" -maxdepth 2 -name "Gruvbox-Plus-Dark" -type d \
    | head -1 | xargs -I{} mv {} "${SRCDIR}/cache/Gruvbox-Plus-Dark"
  rm -rf "${SRCDIR}/cache/${GRUVBOX_ZIP}" "${SRCDIR}/cache/gruvbox-extract/"
fi
